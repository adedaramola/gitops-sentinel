# Local .terraform directories
.terraform/

# .tfstate files
*.tfstate
*.tfstate.*

# Crash log files
crash.log
crash.*.log

# Exclude all .tfvars files, which are likely to contain sensitive data, such as
# password, private keys, and other secrets. These should not be part of version 
# control as they are data points which are potentially sensitive and subject 
# to change depending on the environment.
*.tfvars
*.tfvars.json

# Ignore override files as they are usually used to override resources locally and so
# are not checked in
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# Ignore transient lock info files created by terraform apply
.terraform.tfstate.lock.info

# Include override files you do wish to add to version control using negated pattern
# !example_override.tf

# Ignore tfplan output files (may contain sensitive data)
*tfplan*

# Ignore CLI configuration files
.terraformrc
terraform.rc

# Vim swap files
*.swp
*.swo

.png

# Python
__pycache__/
*.pyc
*.pyo
.venv/
*.egg-info/

# Infracost
.infracost/

# Artifacts
ALL_ARTIFACTS_MANIFEST.md

# Terraform-generated Lambda deployment packages
function.zip
*.zip

# Pip-installed Lambda dependencies (installed into src/ at build time, not source)
terraform/modules/lambda_*/src/bin/
terraform/modules/lambda_*/src/*.dist-info/
terraform/modules/lambda_*/src/certifi/
terraform/modules/lambda_*/src/charset_normalizer/
terraform/modules/lambda_*/src/idna/
terraform/modules/lambda_*/src/requests/
terraform/modules/lambda_*/src/urllib3/
terraform/modules/lambda_*/src/yaml/
terraform/modules/lambda_*/src/_yaml/
terraform/modules/lambda_*/src/*.so
