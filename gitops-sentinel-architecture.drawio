        <!-- Governance → Decision Engine (policy constraints, dashed) -->
        <mxCell id="e25" style="endArrow=block;endFill=0;html=1;dashed=1;" edge="1" parent="1" source="gov" target="decision_engine">
          <mxGeometry relative="1" as="geometry"/>
